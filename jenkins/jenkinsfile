pipeline {
    agent any

    stages {
        stage('Unit Test - Backend') {
            agent {
                docker {
                    image 'golang:1.21-alpine'
                    reuseNode true
                }
            }
            steps {
                dir('bugtracker-backend') {
                    sh '''
                        apk add --no-cache git
                        go install github.com/jstemmer/go-junit-report/v2@latest
                        go test -v ./... 2>&1 | /go/bin/go-junit-report > report.xml
                    '''
                }
            }
        }
    }
}