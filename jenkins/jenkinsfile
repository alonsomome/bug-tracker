pipeline {
    agent any
    stages {
        stage('Execute Unit Tests'){
            parallel {
                stage('Unit Test - Backend') {
                    agent {
                        docker {
                            image 'snakee/golang-junit:1.21'
                            reuseNode true
                            args '-u 0:0'
                        }
                    }
                    steps {
                        dir('bugtracker-backend') {
                            sh '''
                                # 1. Ejecutar pruebas para el reporte gráfico JUnit
                                go test -v ./... 2>&1 | go-junit-report > test-results.xml
                                
                                # 2. Generar datos crudos de cobertura
                                go test -coverprofile=coverage.out -covermode=atomic ./...
                                
                                # 3. Convertir los datos a formato HTML
                                go tool cover -html=coverage.out -o coverage.html
                                
                                # 4. Crear carpeta 'reports' de manera segura y mover el HTML allí
                                mkdir -p reports
                                mv coverage.html reports/
                            '''
                        }
                    }
                    post {
                        always {
                            // Publicar reporte de JUnit (Gráfica de barras)
                            junit 'bugtracker-backend/test-results.xml'
                            
                            // Publicar reporte interactivo de cobertura en HTML
                            publishHTML(target: [                        
                                reportDir: 'bugtracker-backend/reports',
                                reportFiles: 'coverage.html',
                                reportName: 'Back End Coverage'
                            ])
                        }
                    }
                }
                stage('Unit Test - Frontend') {
                    agent {
                        docker {
                            image 'node:20-alpine'
                            reuseNode true
                            args '-u 0:0'
                        }
                    }
                    steps {
                        dir('bugtracker-frontend'){
                            sh '''
                                npm ci
                                npm test
                                mkdir -p reports
                                mv coverage reports/
                            '''
                        }
                    }
                    post {
                        always {
                            junit 'bugtracker-frontend/test-results.xml'
                            publishHTML target: [                        
                                reportDir: 'bugtracker-frontend/reports/coverage',
                                reportFiles: 'index.html',
                                reportName: 'Front End Coverage'
                            ]
                        }
                    }
                }
            }
        }
        stage('Launch Application'){
            agent{
                docker{
                    image 'docker:27.5.1'
                    reuseNode true
                    args '-v /var/run/docker.sock:/var/run/docker.sock -u 0'
                }
            }
            steps{
                sh 'docker compose up --build -d'
            }
        }
        stage('API Tests'){
            agent{
                docker{
                    image 'mcr.microsoft.com/playwright:v1.50.0-jammy'
                    reuseNode true
                    args '-u 0 --network=host'
                }
            }
            steps{
                dir('tests/api') {
                    // Espera hasta 30 segundos a que el Backend responda OK
                    sh 'npx wait-port localhost:8080/health --timeout 30000'
                    sh 'npm ci'
                    sh 'npx playwright test'
                }
            }
        }        
    }
    post {
        always {
            cleanWs()
        }
    }
}