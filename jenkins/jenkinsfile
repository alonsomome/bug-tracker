pipeline {
    agent any

    stages {
        stage('Unit Test - Backend') {
            agent {
                docker {
                    image 'snakee/golang-junit:1.21'
                    reuseNode true
                    args '-u 0:0'
                }
            }
            steps {
                dir('bugtracker-backend'){
                    // Ejecutamos las pruebas y convertimos la salida a XML compatible con JUnit
                    sh 'go test -v ./... 2>&1 | go-junit-report > test-results.xml'
                }
            }
            post {
                always {
                    // Publicamos el reporte XML generado
                    junit 'bugtracker-backend/test-results.xml'
                }
            }
        }
        stage('Unit Test - Frontend') {
            agent {
                docker {
                    image 'node:20-alpine'
                    reuseNode true
                    args '-u 0:0'
                }
            }
            steps {
                dir('bugtracker-frontend'){
                    sh '''
                        npm ci
                        npm test
                    '''
                }
            }
            post {
                always {
                    junit 'bugtracker-frontend/test-results.xml'
                }
            }
        }
    }
}